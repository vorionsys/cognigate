# Cognigate Engine Configuration
# Copy this file to .env and fill in the values

# Application
APP_NAME=Cognigate Engine
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=development

# API
API_PREFIX=/v1

# Security
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
ADMIN_API_KEY=CHANGE_ME_IN_PRODUCTION

# Trust Engine
DEFAULT_TRUST_LEVEL=1
TRUST_DECAY_RATE=0.01

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Critic Pattern - AI Provider Configuration
# Supported: "anthropic" (Claude), "openai" (GPT), "google" (Gemini), "xai" (Grok)
CRITIC_PROVIDER=xai
CRITIC_ENABLED=true
CRITIC_TEMPERATURE=0.3

# API Keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Model settings per provider
CRITIC_MODEL_ANTHROPIC=claude-3-5-sonnet-20241022
CRITIC_MODEL_OPENAI=gpt-4o-mini
CRITIC_MODEL_GOOGLE=gemini-1.5-flash
CRITIC_MODEL_XAI=grok-2-latest

# Database
DATABASE_URL=sqlite+aiosqlite:///./cognigate.db

# Redis (optional - graceful degradation if unavailable)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Signature System (optional - generates dev keys if not set)
SIGNATURE_ENABLED=true
SIGNATURE_PRIVATE_KEY=
SIGNATURE_KEY_PATH=

# Cache TTLs (seconds)
CACHE_TTL_POLICY_RESULTS=60
CACHE_TTL_TRUST_SCORES=300

# Gateway (Vorion proxy)
GATEWAY_UPSTREAM_URL=https://app.vorion.org/api
GATEWAY_TIMEOUT=30
